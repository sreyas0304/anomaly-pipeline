# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Athena — fill in once Firehose -> S3 -> Glue -> Athena is provisioned.
# Leave as-is for now; Grafana will start but queries will fail until Athena exists.

# AWS region where Athena queries run
ATHENA_REGION=us-east-1

# Glue Data Catalog name (leave as AwsDataCatalog unless you create a custom catalog)
ATHENA_CATALOG=AwsDataCatalog

# Glue database name created by the Glue crawler when it crawls the S3 archive bucket
ATHENA_DATABASE=fleet_telemetry_db

# Athena workgroup (use primary unless a named workgroup is created in Terraform)
ATHENA_WORKGROUP=primary

# S3 URI where Athena writes query results — must be a dedicated prefix, trailing slash required
ATHENA_OUTPUT_LOCATION=s3://fleet-telemetry-athena-results/query-results/
